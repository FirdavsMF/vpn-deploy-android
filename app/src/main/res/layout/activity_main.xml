<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1117"
    android:padding="16dp">

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔐 VPN Deploy"
            android:textSize="22sp"
            android:textColor="#ffffff"
            android:textStyle="bold"/>
        
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ OFFLINE"
            android:textSize="12sp"
            android:textColor="#8b949e"
            android:background="#161b22"
            android:android:paddingTop="6dp" android:paddingBottom="6dp" android:paddingLeft="12dp" android:paddingRight="12dp"/>
    </LinearLayout>

    <!-- Server -->
    <EditText
        android:id="@+id/etHost"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="IP адрес VPS"
        android:text="109.237.96.95"
        android:textColor="#c9d1d9"
        android:textColorHint="#484f58"
        android:background="#161b22"
        android:padding="12dp"
        android:textSize="15sp"
        android:layout_marginBottom="8dp"/>
    
    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="SSH пароль"
        android:inputType="textPassword"
        android:textColor="#c9d1d9"
        android:textColorHint="#484f58"
        android:background="#161b22"
        android:padding="12dp"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <!-- Protocol & Mode Selectors -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        
        <Spinner
            android:id="@+id/spProtocol"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="#161b22"
            android:textColor="#58a6ff"/>
        
        <Spinner
            android:id="@+id/spMode"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#161b22"
            android:textColor="#58a6ff"/>
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        
        <Button
            android:id="@+id/btnDeploy"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🚀 DEPLOY"
            android:textColor="#fff"
            android:backgroundTint="#238636"
            android:layout_marginEnd="4dp"/>
        
        <Button
            android:id="@+id/btnStatus"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📊 STATUS"
            android:textColor="#c9d1d9"
            android:backgroundTint="#21262d"
            android:layout_marginEnd="4dp"/>
    </LinearLayout>
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        
        <Button
            android:id="@+id/btnConfigs"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📁 CONFIGS"
            android:textColor="#c9d1d9"
            android:backgroundTint="#21262d"
            android:layout_marginEnd="4dp"/>
        
        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔌 CONNECT"
            android:textColor="#fff"
            android:backgroundTint="#1f6feb"/>
    </LinearLayout>

    <!-- Terminal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#0d1117"
        android:padding="10dp">
        
        <TextView
            android:text="▸ terminal output"
            android:textColor="#8b949e"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>
        
        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            
            <TextView
                android:id="@+id/tvOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00ff41"
                android:typeface="monospace"
                android:textSize="12sp"
                android:text="Готов к работе..."/>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
