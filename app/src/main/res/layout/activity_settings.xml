<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1117"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️ Настройки"
        android:textSize="24sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Добавить сервер"
        android:textColor="#58a6ff"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Название (например: Frankfurt VPS)"
        android:textColor="#c9d1d9"
        android:textColorHint="#484f58"
        android:background="#161b22"
        android:padding="12dp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etHost"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="IP адрес"
        android:textColor="#c9d1d9"
        android:textColorHint="#484f58"
        android:background="#161b22"
        android:padding="12dp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="SSH пароль"
        android:inputType="textPassword"
        android:textColor="#c9d1d9"
        android:textColorHint="#484f58"
        android:background="#161b22"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="💾 Сохранить сервер"
        android:textColor="#ffffff"
        android:backgroundTint="#238636"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Сохраненные серверы"
        android:textColor="#58a6ff"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/lvServers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#161b22"
        android:divider="#21262d"
        android:dividerHeight="1dp"/>

</LinearLayout>
